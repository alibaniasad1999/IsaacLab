# Generated simulation output (regenerated by run_all.sh)
cable_output/
cable_output_archived_*/

# Generated figures (regenerated by report/generate_*.py)
report/figures/

# LaTeX build artifacts
report/*.aux
report/*.log
report/*.out
report/*.fls
report/*.fdb_latexmk
report/*.atfi
report/*.synctex.gz
report/*.nav
report/*.snm
report/*.toc

# LaTeX build artifacts for the slides (cable_slides.tex)
# The .tex is the single source; the PDF in slides_output/slides/ is the build
# output we keep. Everything else LaTeX spits out is scratch -- ignore it.
cable_slides.aux
cable_slides.log
cable_slides.out
cable_slides.fls
cable_slides.fdb_latexmk
cable_slides.synctex.gz
cable_slides.nav
cable_slides.snm
cable_slides.toc
# Stray build of the slides in the source dir (real output lives in slides_output/slides/)
/cable_slides.pdf

# Python cache
__pycache__/
*.pyc
